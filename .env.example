# Discord bot token — Developer Portal → your app → Bot → Reset Token.
# Never commit the real value; .env is gitignored.
DISCORD_TOKEN=your-bot-token-here

# Application (client) id — Developer Portal → your app → General Information.
CLIENT_ID=123456789012345678

# Note: the home guild (the only server CuffBot serves) is NOT an env var —
# it is a non-secret product setting in config.json → homeGuildId.
