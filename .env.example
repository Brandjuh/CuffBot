# Discord bot token — Developer Portal → your app → Bot → Reset Token.
# Never commit the real value; .env is gitignored.
DISCORD_TOKEN=your-bot-token-here

# Application (client) id — Developer Portal → your app → General Information.
CLIENT_ID=123456789012345678

# Note: the home guild (the only server CuffBot serves) is NOT an env var —
# it is a non-secret product setting in config.json → homeGuildId.

# ── Detective (AI) module — optional ────────────────────────────────────────
# Add ONE free-tier API key and restart; without a key the AI commands reply
# "not configured" and everything else works normally.
#   Groq:   https://console.groq.com  → API Keys → Create API Key
#   Gemini: https://aistudio.google.com → Get API key
# GROQ_API_KEY=gsk_your-key-here
# GEMINI_API_KEY=your-key-here

# Optional: pin the provider ("groq" or "gemini") when both keys are set,
# and/or override the model name. Defaults: groq → llama-3.1-8b-instant,
# gemini → gemini-2.0-flash.
# CUFFBOT_AI_PROVIDER=groq
# CUFFBOT_AI_MODEL=llama-3.1-8b-instant
